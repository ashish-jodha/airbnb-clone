<%- layout('layouts/boilerplate') %>

<div class="min-h-[75vh] flex items-center justify-center px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-xl w-full text-center space-y-8">
        
        <div class="relative mx-auto w-24 h-24 mb-4">
            <div class="absolute inset-0 bg-[#FF385C] opacity-10 rounded-full animate-pulse"></div>
            <div class="relative flex items-center justify-center w-full h-full bg-red-50 text-[#FF385C] rounded-full border-4 border-white shadow-sm">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
            </div>
        </div>

        <div>
            <h1 class="text-7xl font-extrabold text-gray-900 tracking-tight mb-2">
                <%= statusCode || 500 %>
            </h1>
            <h2 class="text-3xl font-bold text-gray-900 mb-4 tracking-tight">Something went wrong.</h2>
            
            <p class="text-lg text-gray-600 mb-8 max-w-md mx-auto leading-relaxed">
                We're sorry, but we encountered an unexpected problem while processing your request. Don't worry, your data is safe!
            </p>

            <% if (message) { %>
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-8 mx-auto w-full overflow-x-auto shadow-inner text-left">
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Technical Details</p>
                    <p class="text-sm font-mono text-red-500 whitespace-pre-wrap leading-relaxed"><%= message %></p>
                </div>
            <% } %>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/" class="inline-flex justify-center items-center px-8 py-3.5 border border-gray-300 shadow-sm text-base font-semibold rounded-lg text-gray-700 bg-white hover:bg-gray-50 hover:text-gray-900 transition-colors duration-200">
                Go to Homepage
            </a>
            <a href="/listings" class="inline-flex justify-center items-center px-8 py-3.5 border border-transparent text-base font-semibold rounded-lg text-white bg-[#FF385C] hover:bg-[#D70466] shadow-sm hover:shadow transition-all duration-200">
                Explore Listings
            </a>
        </div>
        
    </div>
</div>