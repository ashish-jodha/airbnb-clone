<%- layout('layouts/boilerplate') %>

<div class="flex items-center justify-center min-h-[75vh] px-4 py-12">
    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        
        <div class="text-center mb-8">
            <svg class="w-10 h-10 text-[#FF385C] mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.25L2 9.25V22h20V9.25L12 2.25zm0 3.25l7 4.9V19.5h-14v-9.1l7-4.9z"/>
            </svg>
            <h2 class="text-2xl font-bold text-gray-900">Welcome to Airbnb</h2>
            <p class="text-gray-500 text-sm mt-2">Create an account to start hosting or booking.</p>
        </div>

        <form action="/signup" method="POST" class="space-y-5 needs-validation group" novalidate>
            
            <div>
                <label for="username" class="block text-sm font-semibold text-gray-900 mb-2">Username</label>
                <input type="text" id="username" name="username" required autofocus
                    class="peer w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#FF385C] outline-none transition-colors group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                <p class="hidden group-[.was-validated]:peer-invalid:block text-red-500 text-xs mt-1">Please pick a username.</p>
            </div>

            <div>
                <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">Email</label>
                <input type="email" id="email" name="email" required
                    class="peer w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#FF385C] outline-none transition-colors group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                <p class="hidden group-[.was-validated]:peer-invalid:block text-red-500 text-xs mt-1">Please enter a valid email address.</p>
            </div>

            <div>
                <label for="password" class="block text-sm font-semibold text-gray-900 mb-2">Password</label>
                <input type="password" id="password" name="password" required
                    class="peer w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#FF385C] outline-none transition-colors group-[.was-validated]:invalid:border-red-500 group-[.was-validated]:valid:border-green-500">
                <p class="hidden group-[.was-validated]:peer-invalid:block text-red-500 text-xs mt-1">Password is required.</p>
            </div>

            <button type="submit" class="w-full bg-[#FF385C] text-white font-bold text-lg py-3.5 rounded-lg shadow-md hover:bg-[#D70466] transition-colors mt-4">
                Sign Up
            </button>
        </form>

        <div class="mt-6 text-center text-sm text-gray-600 border-t border-gray-100 pt-6">
            Already have an account? 
            <a href="/login" class="font-semibold text-gray-900 hover:underline">Log in</a>
        </div>
    </div>
</div>